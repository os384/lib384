{
  "name": "@384/lib",
  "version": "1.0.0.rc2.47",
  "exports": "./src/index.ts",

  "tasks": {
    "build":        "deno run -A build.ts",
    "build:debug":  "deno run -A build.ts --debug",
    "build:debug2": "deno run -A build.ts --debug2",
    "dev":          "deno run -A build.ts --watch",
    "dev:debug":    "deno run -A build.ts --watch --debug",
    "dev:debug2":   "deno run -A build.ts --watch --debug2",

    "test":          "deno test --trace-leaks --no-check --allow-read --allow-write --allow-net --allow-env --allow-run tests/",
    "test:fast":     "deno test --trace-leaks --no-check --allow-read --allow-write --allow-net --allow-env --allow-run --filter='[fast]' tests/",
    "test:channel":  "deno test --trace-leaks --no-check --allow-read --allow-write --allow-net --allow-env --allow-run --filter='[channel]' tests/",
    "test:slow":     "deno test --trace-leaks --no-check --allow-read --allow-write --allow-net --allow-env --allow-run --filter='[slow]' tests/",
    "test:dbg0":     "deno test --trace-leaks --no-check --allow-read --allow-write --allow-net --allow-env --allow-run --filter='[DBG0]' tests/",
    "test:coverage": "deno test --coverage=./tests/coverage --no-check --allow-read --allow-write --allow-net --allow-env --allow-run tests/ && deno coverage --exclude='deno' --exclude='env.js' --exclude='config.js' --exclude='384.esm.js' --lcov tests/coverage/ > tests/coverage/lcov.info",

    "deploy":       "deno run -A tools/deploy.ts",
    "clean":        "rm -rf dist/* build/ tests/coverage/"
  },

  "imports": {
    "@std/assert": "./tests/_std_assert_shim.ts",
    "typescript":  "npm:typescript@5.4.2",

    "src/channel/Channel":        "./src/channel/Channel.ts",
    "src/channel/ChannelApi":     "./src/channel/ChannelApi.ts",
    "src/channel/ChannelHandle":  "./src/channel/ChannelHandle.ts",
    "src/channel/ChannelMessage": "./src/channel/ChannelMessage.ts",
    "src/channel/ChannelSocket":  "./src/channel/ChannelSocket.ts",
    "src/channel/Message":        "./src/channel/Message.ts",
    "src/channel/Protocol":       "./src/channel/Protocol.ts",
    "src/common":                 "./src/common.ts",
    "src/file/SBFile":            "./src/file/SBFile.ts",
    "src/file/SBFileSystem":      "./src/file/SBFileSystem.ts",
    "src/sbCrypto/SBCrypto":      "./src/sbCrypto/SBCrypto.ts",
    "src/sbCrypto/core":          "./src/sbCrypto/core.ts",
    "src/service-worker/db":      "./src/service-worker/db.ts",
    "src/storage/MessageHistory": "./src/storage/MessageHistory.ts",
    "src/storage/ObjectHandle":   "./src/storage/ObjectHandle.ts",
    "src/storage/StorageApi":     "./src/storage/StorageApi.ts",
    "src/storage/StorageToken":   "./src/storage/StorageToken.ts",
    "src/storage/core":           "./src/storage/core.ts",
    "src/types":                  "./src/types.ts",
    "src/utils/AsyncSequence":    "./src/utils/AsyncSequence.ts",
    "src/utils/MessageQueue":     "./src/utils/MessageQueue.ts",
    "src/utils/SBEventTarget":    "./src/utils/SBEventTarget.ts",
    "src/utils/b32mi":            "./src/utils/b32mi.ts",
    "src/utils/b62":              "./src/utils/b62.ts",
    "src/utils/b64":              "./src/utils/b64.ts",
    "src/utils/buffers":          "./src/utils/buffers.ts",
    "src/utils/error":            "./src/utils/error.ts",
    "src/utils/fetch":            "./src/utils/fetch.ts",
    "src/utils/index":            "./src/utils/index.ts",
    "src/utils/json":             "./src/utils/json.ts",
    "src/utils/payloads":         "./src/utils/payloads.ts",
    "src/utils/sep":              "./src/utils/sep.ts",
    "src/utils/timeout":          "./src/utils/timeout.ts"
  }
}
