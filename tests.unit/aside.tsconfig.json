{
    "compilerOptions": {
      "target": "ESNext",
      "module": "ESNext",
      "strict": true,
      "noEmit": true,
      "isolatedModules": true,
      "esModuleInterop": true,
      "experimentalDecorators": true,
      "allowImportingTsExtensions": true,
      "forceConsistentCasingInFileNames": true,
      "lib": ["ESNext", "DOM", "DOM.Iterable"],  
    }
  }
  